---
import "../styles/global.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/lora/400.css";
import "@fontsource/lora/600.css";
import inter400 from "@fontsource/inter/files/inter-latin-400-normal.woff2";
import inter600 from "@fontsource/inter/files/inter-latin-600-normal.woff2";
import lora400 from "@fontsource/lora/files/lora-latin-400-normal.woff2";
import lora600 from "@fontsource/lora/files/lora-latin-600-normal.woff2";

import { ClientRouter } from "astro:transitions";
import { SITE, SOCIALS } from "@consts";

interface Props {
  title: string;
  schemaTitle?: string;
  description: string;
  image?: string;
  pageType?: "website" | "article" | "profile";
  schemaType?: "WebPage" | "CollectionPage" | "ContactPage" | "ProfilePage" | "BlogPosting" | "TechArticle";
  publishedTime?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultImage = "/images/Meromorphy-social.jpg";

const {
  title,
  schemaTitle = title,
  description,
  image = defaultImage,
  pageType = "website",
  schemaType = "WebPage",
  publishedTime,
} = Astro.props;

const imageURL = new URL(image, Astro.site);
const isDefaultImage = image === defaultImage;
const authorURL = new URL("/manifold/", Astro.site);
const websiteID = new URL("/#website", Astro.site).href;
const authorID = new URL("/manifold/#person", Astro.site).href;
const pageID = `${canonicalURL.href}#webpage`;
const publishedISO = publishedTime?.toISOString();
const topicKeywords = SITE.TOPICS.join(", ");
const topicEntities = SITE.TOPICS.map((name) => ({
  "@type": "Thing",
  name,
}));

const pageSchema = {
  "@type": schemaType,
  "@id": pageID,
  url: canonicalURL.href,
  name: schemaTitle,
  description,
  image: imageURL.href,
  isPartOf: { "@id": websiteID },
  inLanguage: "en-US",
  keywords: topicKeywords,
  about: topicEntities,
  ...(pageType === "article" && {
    headline: schemaTitle,
    datePublished: publishedISO,
    author: { "@id": authorID },
  }),
  ...(pageType === "profile" && {
    mainEntity: { "@id": authorID },
  }),
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteID,
      url: new URL("/", Astro.site).href,
      name: SITE.NAME,
      alternateName: SITE.TAGLINE,
      description: "An independent website for essays and interactive projects on science, mathematics, data science, artificial intelligence, innovation, and human experience.",
      inLanguage: "en-US",
      keywords: topicKeywords,
      about: topicEntities,
      author: { "@id": authorID },
    },
    {
      "@type": "Person",
      "@id": authorID,
      name: SITE.AUTHOR,
      url: authorURL.href,
      knowsAbout: topicEntities,
      sameAs: SOCIALS.map((social) => social.HREF),
    },
    pageSchema,
  ],
};
---

<!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NBZ4SCSG8C" data-cfasync="false"></script>
<script is:inline data-cfasync="false">
  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function(){window.dataLayer.push(arguments);}

  if (!window.__meromorphyGtagInitialized) {
    window.__meromorphyGtagInitialized = true;
    window.gtag("js", new Date());
    window.gtag("config", "G-NBZ4SCSG8C");
  }

  if (!window.__meromorphyGtagPageViewsBound) {
    window.__meromorphyGtagPageViewsBound = true;
    document.addEventListener("astro:after-swap", () => {
      window.gtag("config", "G-NBZ4SCSG8C", {
        page_location: window.location.href,
        page_path: window.location.pathname + window.location.search,
        page_title: document.title,
      });
    });
  }
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#f5f5f4" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#1c1917" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon/favicon-16x16.png">
<link rel="icon" type="image/png" sizes="96x96" href="/images/favicon/favicon-96x96.png">
<link rel="icon" type="image/x-icon" href="/images/favicon/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-icon-180x180.png">
<link rel="manifest" href="/images/favicon/site.webmanifest">
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href={inter400} as="font" type="font/woff2" crossorigin/>
<link rel="preload" href={inter600} as="font" type="font/woff2" crossorigin/>
<link rel="preload" href={lora400} as="font" type="font/woff2" crossorigin/>
<link rel="preload" href={lora600} as="font" type="font/woff2" crossorigin/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE.AUTHOR} />
<meta name="keywords" content={topicKeywords} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType === "article" ? "article" : pageType === "profile" ? "profile" : "website"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE.NAME} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:alt" content={`${schemaTitle} - ${SITE.NAME}`} />
{isDefaultImage && <meta property="og:image:type" content="image/jpeg" />}
{isDefaultImage && <meta property="og:image:width" content="1200" />}
{isDefaultImage && <meta property="og:image:height" content="540" />}
{publishedISO && <meta property="article:published_time" content={publishedISO} />}
{pageType === "article" && <meta property="article:author" content={authorURL} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={`${schemaTitle} - ${SITE.NAME}`} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

<ClientRouter  />

<!-- RSS Link -->
<link rel="alternate" type="application/rss+xml" title={SITE.NAME} href={new URL("rss.xml", Astro.site)} />

<script>
  import type { TransitionBeforeSwapEvent } from "astro:transitions/client";
  document.addEventListener("astro:before-swap", (e) =>
    [
      ...(e as TransitionBeforeSwapEvent).newDocument.head.querySelectorAll(
        "link[as=\"font\"]"
      ),
    ].forEach((link) => link.remove())
  );
</script>

<script is:inline>
  function init() {
    preloadTheme();
    onScroll();
    animate();

    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", (event) => scrollToTop(event));

    const backToPrev = document.getElementById("back-to-prev");
    backToPrev?.addEventListener("click", () => window.history.back());

    const lightThemeButton = document.getElementById("light-theme-button");
    lightThemeButton?.addEventListener("click", () => {
      localStorage.setItem("theme", "light");
      toggleTheme(false);
    });

    const darkThemeButton = document.getElementById("dark-theme-button");
    darkThemeButton?.addEventListener("click", () => {
      localStorage.setItem("theme", "dark");
      toggleTheme(true);
    });

    const systemThemeButton = document.getElementById("system-theme-button");
    systemThemeButton?.addEventListener("click", () => {
      localStorage.setItem("theme", "system");
      toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
    });

    bindInteractiveResidueMessages();

    document.querySelectorAll(".interactive-residue-frame").forEach((frame) => {
      if (frame.dataset.interactiveResidueBound) return;
      frame.dataset.interactiveResidueBound = "true";
      frame.addEventListener("load", () => {
        syncInteractiveResidueTheme();
        resizeInteractiveResidueFrame(frame);
      });
    });
    syncInteractiveResidueTheme();

    window.matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", event => {
        if (localStorage.theme === "system") {
          toggleTheme(event.matches);
        }
      }
    );

    document.addEventListener("scroll", onScroll);
  }

  function animate() {
    const animateElements = document.querySelectorAll(".animate");

    animateElements.forEach((element, index) => {
      setTimeout(() => {
        element.classList.add("show");
      }, index * 150);
    });
  }

  function onScroll() {
    if (window.scrollY > 0) {
      document.documentElement.classList.add("scrolled");
    } else {
      document.documentElement.classList.remove("scrolled");
    }
  }

  function scrollToTop(event) {
    event.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth"
    });
  }

function toggleTheme(dark) {
    const css = document.createElement("style");

    css.appendChild(
      document.createTextNode(
        `* {
             -webkit-transition: none !important;
             -moz-transition: none !important;
             -o-transition: none !important;
             -ms-transition: none !important;
             transition: none !important;
          }
        `,
      )
    );

    document.head.appendChild(css);

    if (dark) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }

    syncInteractiveResidueTheme();

  window.getComputedStyle(css).opacity;
    document.head.removeChild(css);
  }

  function syncInteractiveResidueTheme() {
    const theme = document.documentElement.classList.contains("dark") ? "dark" : "light";
    const targetOrigin = window.location.origin === "null" ? "*" : window.location.origin;

    document.querySelectorAll(".interactive-residue-frame").forEach((frame) => {
      frame.contentWindow?.postMessage(
        { type: "meromorphy:theme", theme },
        targetOrigin
      );
    });
  }

  function bindInteractiveResidueMessages() {
    if (window.__interactiveResidueMessagesBound) return;
    window.__interactiveResidueMessagesBound = "true";
    window.addEventListener("message", handleInteractiveResidueMessage);
  }

  function handleInteractiveResidueMessage(event) {
    if (window.location.origin !== "null" && event.origin !== window.location.origin) return;

    if (event.data?.type === "meromorphy:theme-ready") {
      syncInteractiveResidueTheme();
      return;
    }

    if (event.data?.type !== "meromorphy:interactive-height") return;

    const height = Number(event.data.height);
    if (!Number.isFinite(height) || height <= 0) return;

    document.querySelectorAll(".interactive-residue-frame").forEach((frame) => {
      if (frame.contentWindow === event.source) {
        frame.style.height = `${Math.max(320, Math.ceil(height))}px`;
      }
    });
  }

  function resizeInteractiveResidueFrame(frame) {
    try {
      const doc = frame.contentDocument;
      const shell = doc?.querySelector(".page-shell");
      const shellBottom = shell?.getBoundingClientRect().bottom || 0;
      const fallback = Math.max(
        doc?.documentElement?.scrollHeight || 0,
        doc?.body?.scrollHeight || 0
      );
      const height = Math.max(shellBottom, fallback);

      if (height > 0) {
        frame.style.height = `${Math.ceil(height)}px`;
      }
    } catch {
      // Cross-origin frames keep their static fallback height.
    }
  }

  function preloadTheme() {
    const userTheme = localStorage.theme;

    if (userTheme === "light" || userTheme === "dark") {
      toggleTheme(userTheme === "dark");
      return;
    }

    if (userTheme === "system") {
      toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
      return;
    }

    localStorage.setItem("theme", "dark");
    toggleTheme(true);
  }

  document.addEventListener("DOMContentLoaded", () => init());
  document.addEventListener("astro:after-swap", () => init());
  preloadTheme();
</script>
